NEXT_PUBLIC_SITE_URL=https://www.coldstonesoap.com
NEXT_PUBLIC_SOAP_ABACUS_URL=https://www.soapabacus.com

# Clerk account-backed Recipe Vault
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Neon Postgres Recipe Vault
DATABASE_URL=postgres://replace_me

# AI Recipe Generator
AI_PROVIDER=nvidia
NVIDIA_API_KEY=nvapi_replace_me
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=minimaxai/minimax-m2.7

# Optional OpenAI fallback for the AI Recipe Generator
OPENAI_API_KEY=sk-proj_replace_me
OPENAI_MODEL=gpt-5.5

# Optional Vercel Blob PDF artifact storage
BLOB_READ_WRITE_TOKEN=vercel_blob_replace_me

# Stripe server credentials
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe Price IDs from the Coldstone Stripe product catalog
STRIPE_PRICE_BLACK_GRANITE=price_replace_black_granite
STRIPE_PRICE_STONE_FORGE=price_replace_stone_forge

# Stripe Price IDs from the Soap Abacus subscription catalog
STRIPE_PRICE_SOAP_ABACUS_PLUS=price_replace_soap_abacus_plus
STRIPE_PRICE_SOAP_ABACUS_PRO=price_replace_soap_abacus_pro

# Optional simple US shipping rate configured in Stripe Dashboard
STRIPE_SHIPPING_RATE_US=shr_replace_us_flat_rate

# Enable after Stripe Tax has a valid head office address and tax profile
STRIPE_AUTOMATIC_TAX_ENABLED=false
